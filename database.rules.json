{
  "rules": {

    "roles": {
      "$uid": {
        ".read":  "auth != null && (auth.uid === $uid || root.child('roles').child(auth.uid).child('appRole').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('roles').child(auth.uid).child('appRole').val() === 'admin')",
        ".validate": "newData.hasChildren(['appRole', 'updatedAtMillis'])",

        "appRole": {
          ".validate": "(!data.exists() && (newData.val() === 'patient' || newData.val() === 'doctor')) || data.val() === newData.val()"
        },

        "verificationStatus": {
          ".validate": "newData.isString() && (newData.val() === 'pending' || (data.exists() && data.val() === newData.val()) || root.child('roles').child(auth.uid).child('appRole').val() === 'admin')"
        },

        "updatedAtMillis": {
          ".validate": "newData.isNumber()"
        }
      }
    },

    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",

        "profile": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.hasChildren(['encryptedData', 'nameHash', 'age', 'gender'])"
        },

        "appointments": {
          "$appointmentId": {
            ".write": "auth != null && (auth.uid === $uid || (root.child('roles').child(auth.uid).child('appRole').val() === 'doctor' && root.child('roles').child(auth.uid).child('verificationStatus').val() === 'approved' && (!data.exists() || data.child('doctorId').val() === auth.uid || newData.child('doctorId').val() === auth.uid)))",
            ".validate": "!newData.exists() || newData.hasChildren(['id', 'dateTimeUtcMillis', 'tokenNumber', 'status', 'doctorId'])"
          }
        },

        "notifications": {
          "$notificationId": {
            ".write": "auth != null && (auth.uid === $uid || (root.child('roles').child(auth.uid).child('appRole').val() === 'doctor' && root.child('roles').child(auth.uid).child('verificationStatus').val() === 'approved'))",
            ".validate": "!newData.exists() || newData.hasChildren(['id', 'title', 'message', 'type', 'isUnread'])"
          }
        },

        "ai_chat_history": {
          ".write": "auth != null && auth.uid === $uid"
        },

        "chat_sessions": {
          ".write": "auth != null && auth.uid === $uid"
        },

        "sync_telemetry": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },

    "patient_records": {
      "$patientUid": {
        ".read": "auth != null && auth.uid === $patientUid",

        "$recordId": {
          ".write": "auth != null && (auth.uid === $patientUid || root.child('roles').child(auth.uid).child('appRole').val() === 'doctor' && root.child('roles').child(auth.uid).child('verificationStatus').val() === 'approved')",
          ".validate": "!newData.exists() || newData.hasChildren(['encryptedPayload', 'dateUtcMillis', 'updatedAtMillis'])"
        }
      }
    },

    "patient_reminders": {
      "$patientUid": {
        ".read": "auth != null && auth.uid === $patientUid",

        "$reminderId": {
          ".write": "auth != null && (auth.uid === $patientUid || root.child('roles').child(auth.uid).child('appRole').val() === 'doctor' && root.child('roles').child(auth.uid).child('verificationStatus').val() === 'approved')",
          ".validate": "!newData.exists() || newData.hasChildren(['id', 'isEnabled'])"
        }
      }
    },

    "patient_prescriptions": {
      "$patientUid": {
        ".read": "auth != null && auth.uid === $patientUid",

        "$prescriptionId": {
          ".write": "auth != null && (auth.uid === $patientUid || root.child('roles').child(auth.uid).child('appRole').val() === 'doctor' && root.child('roles').child(auth.uid).child('verificationStatus').val() === 'approved')",
          ".validate": "!newData.exists() || newData.hasChildren(['encryptedPayload', 'dateUtcMillis', 'updatedAtMillis'])"
        }
      }
    },

    "patient_queue_snapshots": {
      "$patientUid": {
        ".read": "auth != null && auth.uid === $patientUid",
        ".write": "auth != null && (auth.uid === $patientUid || root.child('roles').child(auth.uid).child('appRole').val() === 'doctor' && root.child('roles').child(auth.uid).child('verificationStatus').val() === 'approved')",
        ".validate": "!newData.exists() || newData.hasChildren(['doctorName', 'doctorId', 'yourToken', 'currentToken', 'patientsAhead'])"
      }
    },

    "doctors": {
      "$uid": {
        "queue": {
          ".read":  "auth != null && auth.uid === $uid",
          "$caseId": {
            ".read":  "auth != null && auth.uid === $uid",
            ".write": "auth != null && (auth.uid === $uid || (newData.exists() && newData.child('patientUid').val() === auth.uid))",
            ".validate": "!newData.exists() || (newData.hasChildren(['patientUid', 'token', 'age', 'gender', 'encryptedPayload']) && newData.child('patientUid').val() === auth.uid)"
          }
        },

        "schedule": {
          ".read":  "auth != null",
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.hasChildren(['workingDays', 'morningStart', 'morningEnd'])"
        },

        "booked_slots": {
          ".read": "auth != null",
          "$date": {
            "$slot": {
              ".write": "auth != null && (!data.exists() || !newData.exists())",
              ".validate": "newData.isString()"
            }
          }
        }
      }
    },

    "catalog": {
      "doctors": {
        ".read": "auth != null",

        "$doctorId": {
          ".write": "auth != null && (auth.uid === $doctorId || root.child('roles').child(auth.uid).child('appRole').val() === 'admin')",
          ".validate": "newData.hasChildren(['id', 'name', 'specialty', 'hospital', 'rating'])"
        }
      }
    },

    "doctor_applications": {
      ".read": "auth != null && root.child('roles').child(auth.uid).child('appRole').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('roles').child(auth.uid).child('appRole').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('roles').child(auth.uid).child('appRole').val() === 'admin')"
      }
    }

  }
}
